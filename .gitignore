# ##############################################################################
# AttendX Root .gitignore
# Co-existing Flutter and Next.js projects
# ##############################################################################

# IDE / Editor specific
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.iml
*.ipr
*.iws
.classpath
.project
.settings/
*.sublime-project
*.sublime-workspace

# OS / System specific
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Log files
# ------------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Node / Web (Next.js) general
# ------------------------------------------------------------------------------
node_modules/
.next/
out/
dist/
build/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.vercel/
*.tsbuildinfo
next-env.d.ts

# Flutter / Dart / Mobile general
# ------------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/
doc/api/
ios/Flutter/.last_build_id
app.*.symbols
app.*.map.json
android/app/debug
android/app/profile
android/app/release

# Xcode specific
# ------------------------------------------------------------------------------
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh

# Temporary / Application bundles / Tools specific to the environment
# ------------------------------------------------------------------------------
Antigravity IDE/
Antigravity IDE.tar.gz
*.tar.gz
*.zip
*.rar

# Environment configuration files (Sensitive data)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
